{
  "theme": "auto",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/root/astra-config/scripts/commit-if-changed.sh /root/astra-config"
          },
          {
            "type": "command",
            "command": "/root/astra-config/scripts/warn-uncommitted.sh"
          }
        ]
      }
    ]
  }
}
