# Template for /etc/grok-mcp.env  —  copy, fill, chmod 600. NEVER commit the filled file.
#   cp .env.example /etc/grok-mcp.env && chmod 600 /etc/grok-mcp.env && edit it
#
# These two keys are the ONLY manual inputs needed to bring the box back up.

# xAI / Grok key  —  https://console.x.ai  (format: xai-...)
# Powers: ask_grok, grok_x_search.  Set a SPEND CAP.
XAI_API_KEY=

# Google Gemini key  —  https://aistudio.google.com  ("Get API key")
# Powers: ask_panel gemini specs on the DIRECT transport. IMPORTANT: RESTRICT the
# key to the "Generative Language API" (Gemini) in Google Cloud console, or calls
# are blocked. Set a spend cap there too.
GEMINI_API_KEY=

# --- Gemini transport (OpenRouter BYOK) --- OPTIONAL.
# ask_panel's gemini specs can reach Google either directly (@google/genai SDK,
# uses GEMINI_API_KEY) or through OpenRouter's OpenAI-compatible endpoint (BYOK:
# add the same AI Studio key as a provider key in the OpenRouter dashboard so
# google/* calls bill your AI Studio credits). See grok-mcp/README.md.
#   GEMINI_TRANSPORT=direct      (default) — SDK path, native Google grounding.
#   GEMINI_TRANSPORT=openrouter  — route gemini specs via OpenRouter; grounded
#                                  specs force the web plugin engine:"native".
# OPENROUTER_API_KEY is only needed when GEMINI_TRANSPORT=openrouter.
# OpenRouter key — https://openrouter.ai/keys (format: sk-or-...). Set a spend cap.
GEMINI_TRANSPORT=direct
OPENROUTER_API_KEY=

# --- MCP mount path --- REQUIRED. The server reads its public mount path here
# (comma-separated for multiple mounts). Treat it like a credential: use a long
# random value and rotate it whenever you want to invalidate the old one.
#   e.g.  MCP_PATH=/mcp/$(openssl rand -hex 12)
MCP_PATH=

# --- Alert email (Resend) --- OPTIONAL. Powers health-check + push-fail alerts.
# Without RESEND_API_KEY all alert emails safely no-op (scripts still run).
# Resend key — https://resend.com. TESTING MODE (no verified domain): Resend will
# ONLY deliver from onboarding@resend.dev to the account's OWN signup email. This
# account was created via GitHub OAuth, so that address is the GitHub primary email
# zzuliani343@insite.4cd.edu — NOT zazesty@gmail.com. Sending anywhere else => 403.
# So while in testing mode, NOTIFY_EMAIL_TO must be the .edu address.
# To send to Gmail: verify a domain at resend.com/domains, then set
# NOTIFY_EMAIL_FROM=alerts@<domain> and NOTIFY_EMAIL_TO=zazesty@gmail.com.
RESEND_API_KEY=
NOTIFY_EMAIL_TO=zzuliani343@insite.4cd.edu
# NOTIFY_EMAIL_FROM=onboarding@resend.dev   # override only after you verify a domain
